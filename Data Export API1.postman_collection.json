      "name": "Data Export API",
      "item": [
        {
          "name": "Get Fields",
          "item": [
            {
              "name": "Export Fields",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{bearerToken}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseURL}}/{{exportAPIPath}}/fields?entityType=Account",
                  "host": [
                    "{{baseURL}}"
                  ],
                  "path": [
                    "{{exportAPIPath}}",
                    "fields"
                  ],
                  "query": [
                    {
                      "key": "entityType",
                      "value": "Account"
                    }
                  ]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "Create Export Job",
          "item": [
            {
              "name": "Create Export Job (Account, Opp, Person, Activity, Campaign, Creative)",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{bearerToken}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"jobName\": \"activity_test_export_highkeywords\",\n    \"entityType\": \"Activity\",\n    \"limit\": \"10\",\n    \"fromDate\": \"2026-02-13\",\n    \"toDate\": \"2026-04-14\",\n    \"filters\": [\n        {\n            \"field\": \"{Activity}.highKeywords\",\n            \"operator\": \"Exists\"\n        },\n        {\n            \"field\": \"{Activity}.activityType\",\n            \"operator\": \"Contains\",\n            \"values\": [\"keyword\", \"Keyword\"]\n        }\n    ],\n    \"fields\": [\n        \"{Activity}.id\",\n        \"{Account}.id\",\n        \"{Activity}.accountDomain\",\n        \"{Activity}.activityDate\",\n        \"{Activity}.activityType\",\n        \"{Activity}.highKeywords\",\n        \"{Activity}.medKeywords\",\n        \"{Activity}.lowKeywords\",\n        \"{Activity}.keyword_set\"\n    ]\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{baseURL}}/{{exportAPIPath}}/job",
                  "host": [
                    "{{baseURL}}"
                  ],
                  "path": [
                    "{{exportAPIPath}}",
                    "job"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Create third-party campaign export job (LinkedIn and Google only)",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{bearerToken}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"entityType\": \"campaign\",  //Required to be campaign\n  \"jobName\": \"ThirdPartyCampaignExportJob\",\n  \"jobType\": \"campaign_summary\", //Required to be campaign_summary\n  \"source\": [  //linkedin, google, or all\n    \"linkedin\",\n    \"google\"\n  ],\n  \"fields\": [\n    \"campaignId\",\n    \"campaignName\",\n    \"campaignSource\",\n    \"startDate\",\n    \"endDate\"\n  ]\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{baseURL}}/{{exportAPIPath}}/job",
                  "host": [
                    "{{baseURL}}"
                  ],
                  "path": [
                    "{{exportAPIPath}}",
                    "job"
                  ]
                }
              },
              "response": []
            },
